# Tipay — Environment Variables for Deployment
# Copy to .env.deploy and fill in your values

# Stellar network (testnet | mainnet)
STELLAR_NETWORK=testnet

# Your Stellar identity (created with: stellar keys generate --global alice --network testnet --fund)
STELLAR_SOURCE_IDENTITY=alice

# Optional: set secret key directly (if not using stored identity)
# STELLAR_SECRET_KEY=S...

# Stellar Asset Contract address for the token used in sessions.
# For native XLM on testnet and mainnet:
#   TOKEN_SAC_ADDRESS=CDMLFMKMMD7MWZP3FKUBZPVEGUJYXKAKHNBYJKPQXKTBBSBKKYRDQ7Y6
TOKEN_SAC_ADDRESS=CDMLFMKMMD7MWZP3FKUBZPVEGUJYXKAKHNBYJKPQXKTBBSBKKYRDQ7Y6
