# Tipay — Environment Variables for Deployment
# Copy to .env.deploy and fill in your values

# Stellar network (testnet | mainnet)
STELLAR_NETWORK=testnet

# Your Stellar identity (created with: stellar keys generate --global alice --network testnet --fund)
STELLAR_SOURCE_IDENTITY=alice

# Optional: set secret key directly (if not using stored identity)
# STELLAR_SECRET_KEY=S...

# USDC Stellar Asset Contract address (network-specific!)
# Testnet example: CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMIHG
# Mainnet example: CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMIHG
TOKEN_SAC_ADDRESS=

# Contract owner address (receives 10% fee when sessions finalize)
# This is a Stellar account address starting with G...
OWNER_ADDRESS=
